# fastlane lanes for the CyberOS iOS app (Capacitor -> apps/web/ios/App).
#
# Until this file existed, .github/workflows/release.yml's `ios` job ran:
#
#     run: echo "Run fastlane beta (see docs/deploy/RELEASE.md) ..."
#
# ...which means that with IOS_RELEASE=true the job archived nothing, uploaded nothing, and reported
# SUCCESS. A green iOS job that ships nothing is worse than a red one, because nobody goes looking.
#
# Authentication is an App Store Connect API key (NOT an Apple ID + app-specific password): the password
# flow trips 2FA in CI and cannot upload to TestFlight unattended. The key is passed as three secrets -
# see the `ios` job in release.yml for the exact names and how to mint them.
#
# Signing is Xcode automatic signing driven by that same API key (`-allowProvisioningUpdates`), so no
# certificate or provisioning profile is committed, and no `match` repo is needed. The key must have the
# App Manager role for Xcode to be allowed to create the distribution certificate and profile.

default_platform(:ios)

APP_IDENTIFIER = "os.cyberskill.world".freeze

platform :ios do
  # Fail early and in plain language. Without this, a missing secret surfaces 20 minutes later as an
  # inscrutable codesign error, which is how an afternoon disappears.
  def api_key!
    missing = %w[APP_STORE_CONNECT_KEY_ID APP_STORE_CONNECT_ISSUER_ID APP_STORE_CONNECT_API_KEY APPLE_TEAM_ID]
              .reject { |k| ENV[k].to_s.strip != "" }
    unless missing.empty?
      UI.user_error!(
        "missing required environment: #{missing.join(', ')}.\n" \
        "These are GitHub secrets on this repo. See the `ios` job in .github/workflows/release.yml for how " \
        "to mint the App Store Connect API key. iOS cannot be built or uploaded without them."
      )
    end

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"), # the .p8, base64-encoded
      is_key_content_base64: true,
      in_house: false,
    )
  end

  desc "Archive the app and upload the build to TestFlight"
  lane :beta do
    key = api_key!

    # The version + build number are stamped into the Xcode project by scripts/stamp-release-version.mjs
    # from the root VERSION, BEFORE this lane runs (see the `ios` job). Do not set them here - two places
    # deciding one number is how they drift. Read them back only to put them in the log.
    UI.message("archiving #{APP_IDENTIFIER} from the Capacitor project")

    # `project:`, NOT `workspace:`. Capacitor 8 uses Swift Package Manager (CapApp-SPM), not CocoaPods, so
    # it never generates an App.xcworkspace - only App.xcodeproj. The first real CI run died on
    # "Workspace file not found at path .../App.xcworkspace" after a clean checkout, npm ci and cap sync,
    # because the CocoaPods-era layout was assumed. There is nothing to point a workspace at.
    #
    # `scheme: "App"` resolves to the SHARED scheme committed at
    # App.xcodeproj/xcshareddata/xcschemes/App.xcscheme. Xcode's auto-created schemes live in xcuserdata/,
    # which is per-user and gitignored, so on a CI runner they simply do not exist.
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      # Let Xcode create/refresh the distribution certificate and provisioning profile using the API key.
      # This is what removes the need for a committed cert or a `match` repo.
      # DEVELOPMENT_TEAM has to be passed as a BUILD SETTING, not just in export_options. Capacitor
      # scaffolds the project with CODE_SIGN_STYLE = Automatic and an EMPTY DEVELOPMENT_TEAM, and
      # export_options only applies at the export step - by which point the ARCHIVE has already failed with
      # "Signing for \"App\" requires a development team". Setting it here means the Team ID stays in the
      # secret instead of being committed into project.pbxproj.
      #
      # -allowProvisioningUpdates lets Xcode create/refresh the distribution certificate and provisioning
      # profile from the App Store Connect key (which is why that key needs the App Manager role).
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
      },
      output_directory: "build",
      clean: true,
    )

    # skip_waiting_for_build_processing: the upload is the deliverable. Apple's processing can take 30+
    # minutes and blocking a CI runner on it burns money for no added certainty - if the binary is bad,
    # App Store Connect emails about it.
    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      # No changelog here: TestFlight "What to Test" is a release-notes decision, not a build artefact.
      distribute_external: false,
    )
  end
end
