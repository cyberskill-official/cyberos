# fastlane lanes for the CyberOS iOS app (Capacitor -> apps/web/ios/App).
#
# Until this file existed, .github/workflows/release.yml's `ios` job ran:
#
#     run: echo "Run fastlane beta (see docs/deploy/RELEASE.md) ..."
#
# ...which means that with IOS_RELEASE=true the job archived nothing, uploaded nothing, and reported
# SUCCESS. A green iOS job that ships nothing is worse than a red one, because nobody goes looking.
#
# Authentication is an App Store Connect API key (NOT an Apple ID + app-specific password): the password
# flow trips 2FA in CI and cannot upload to TestFlight unattended. The key is passed as three secrets -
# see the `ios` job in release.yml for the exact names and how to mint them.
#
# Signing is Xcode automatic signing driven by that same API key, so no certificate or provisioning
# profile is committed, and no `match` repo is needed. The key must have the App Manager role for Xcode to
# be allowed to create the distribution certificate and profile.

require "base64"
require "tmpdir"
require "fileutils"
require "shellwords"

default_platform(:ios)

APP_IDENTIFIER = "os.cyberskill.world".freeze

platform :ios do
  # Fail early and in plain language. Without this, a missing secret surfaces 20 minutes later as an
  # inscrutable codesign error, which is how an afternoon disappears.
  def require_env!
    missing = %w[APP_STORE_CONNECT_KEY_ID APP_STORE_CONNECT_ISSUER_ID APP_STORE_CONNECT_API_KEY APPLE_TEAM_ID]
              .reject { |k| ENV[k].to_s.strip != "" }
    return if missing.empty?

    UI.user_error!(
      "missing required environment: #{missing.join(', ')}.\n" \
      "These are GitHub secrets on this repo. See the `ios` job in .github/workflows/release.yml for how " \
      "to mint the App Store Connect API key. iOS cannot be built or uploaded without them."
    )
  end

  # Write the .p8 to a real file on disk and return its ABSOLUTE path.
  #
  # This exists because of a specific, non-obvious gap: `app_store_connect_api_key` authenticates
  # fastlane's OWN API calls (the TestFlight upload). It does NOT authenticate `xcodebuild`. They are
  # separate processes, and xcodebuild never sees fastlane's token. `build_app` has no `api_key` parameter
  # either - check the docs before "fixing" this by adding one.
  #
  # So with only -allowProvisioningUpdates set, xcodebuild had no credentials at all. It fell back to
  # looking for a signed-in Xcode account, found none on a CI runner, and failed with:
  #
  #     error: No Accounts: Add a new account in Accounts settings.
  #     error: No profiles for 'os.cyberskill.world' were found
  #
  # The fix is to hand xcodebuild the key directly via -authenticationKeyPath / -authenticationKeyID /
  # -authenticationKeyIssuerID (Xcode 13+). The path MUST be absolute; a relative one is ignored.
  def write_api_key_file!
    dir = File.join(Dir.tmpdir, "cyberos-asc")
    FileUtils.mkdir_p(dir)
    path = File.join(dir, "AuthKey_#{ENV.fetch('APP_STORE_CONNECT_KEY_ID')}.p8")
    File.write(path, Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY")))
    File.chmod(0o600, path)
    if File.size(path).zero?
      UI.user_error!("the decoded App Store Connect key is empty - is APP_STORE_CONNECT_API_KEY the base64 of the .p8?")
    end
    path
  end

  desc "Archive the app and upload the build to TestFlight"
  lane :beta do
    require_env!

    team_id   = ENV.fetch("APPLE_TEAM_ID")
    key_id    = ENV.fetch("APP_STORE_CONNECT_KEY_ID")
    issuer_id = ENV.fetch("APP_STORE_CONNECT_ISSUER_ID")
    key_path  = write_api_key_file!

    # Authenticates fastlane itself - used by upload_to_testflight at the end of this lane.
    key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY"), # the .p8, base64-encoded
      is_key_content_base64: true,
      in_house: false,
    )

    # The version + build number are stamped into the Xcode project by scripts/stamp-release-version.mjs
    # from the root VERSION and BUILD_NUMBER, BEFORE this lane runs (see the `ios` job). Do not set them
    # here - two places deciding one number is how they drift.
    UI.message("archiving #{APP_IDENTIFIER} from the Capacitor project")

    # Every argument below is load-bearing, and each one was paid for with a failed CI run:
    #
    #   -allowProvisioningUpdates  lets Xcode create/refresh the distribution certificate and provisioning
    #                              profile instead of requiring a committed one or a `match` repo.
    #   -authenticationKey*        the credentials that let it actually do that (see write_api_key_file!).
    #   DEVELOPMENT_TEAM           must be a BUILD SETTING, not just export_options. Capacitor scaffolds
    #                              the project with CODE_SIGN_STYLE = Automatic and an EMPTY team, and
    #                              export_options only applies at EXPORT - by which point the ARCHIVE has
    #                              already failed with 'Signing for "App" requires a development team'.
    #                              Passing it here keeps the Team ID in a secret, out of project.pbxproj.
    #
    # CODE_SIGN_IDENTITY is deliberately NOT set here: it now lives in project.pbxproj, where the Release
    # config says "Apple Distribution" (Capacitor scaffolds it as "iPhone Developer", which is why Xcode
    # went hunting for a *development* profile and could not find one).
    xcargs = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{Shellwords.escape(key_path)}",
      "-authenticationKeyID #{Shellwords.escape(key_id)}",
      "-authenticationKeyIssuerID #{Shellwords.escape(issuer_id)}",
      "DEVELOPMENT_TEAM=#{Shellwords.escape(team_id)}",
    ].join(" ")

    # `project:`, NOT `workspace:`. Capacitor 8 uses Swift Package Manager (CapApp-SPM), not CocoaPods, so
    # it never generates an App.xcworkspace - only App.xcodeproj. The first real CI run died on
    # "Workspace file not found at path .../App.xcworkspace". There is nothing to point a workspace at.
    #
    # `scheme: "App"` resolves to the SHARED scheme committed at
    # App.xcodeproj/xcshareddata/xcschemes/App.xcscheme. Xcode's auto-created schemes live in xcuserdata/,
    # which is per-user and gitignored, so on a CI runner they simply do not exist.
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: xcargs,
      export_options: {
        signingStyle: "automatic",
        teamID: team_id,
      },
      output_directory: "build",
      clean: true,
    )

    # skip_waiting_for_build_processing: the upload is the deliverable. Apple's processing can take 30+
    # minutes and blocking a CI runner on it burns money for no added certainty - if the binary is bad,
    # App Store Connect emails about it.
    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      # No changelog here: TestFlight "What to Test" is a release-notes decision, not a build artefact.
      distribute_external: false,
    )
  end
end
