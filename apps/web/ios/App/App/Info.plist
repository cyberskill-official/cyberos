<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>CyberOS</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Answers the export-compliance question in the binary instead of in the App Store Connect UI, where
	     it is otherwise asked on EVERY upload and blocks the build from being submitted until answered.
	     Declaring it here removes a manual step per release and, more to the point, removes the chance of
	     answering it wrong in a hurry. CyberOS qualifies for the exemption: its only cryptography is the
	     platform's own - HTTPS/TLS to its API and the standard WebRTC media stack for calls - and it ships
	     no custom, proprietary or non-standard cryptography of its own.
	     Revisit this the moment that stops being true. This is an export-compliance declaration, not a
	     formality, and a false one is a misstatement rather than a mis-set build flag. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Purpose strings. These are NOT optional and NOT cosmetic: iOS terminates the process the instant an
	     app touches the mic, camera or photo library without the matching key, and App Review rejects the
	     build for it. CyberOS reaches all three from the WKWebView:
	       - mic + camera: lib/call.ts does getUserMedia({ audio: true, video }) for 1:1 WebRTC calls, so the
	         FIRST call any tester places would have crashed the app.
	       - photo library: the chat composer's file input (Chat.tsx) opens the system picker for attachments.
	     Written in the second person and naming the feature, because a vague string is itself a rejection
	     reason ("we need access to your camera" is not an explanation). -->
	<key>NSMicrophoneUsageDescription</key>
	<string>CyberOS uses your microphone so you can talk during voice and video calls with your team.</string>
	<key>NSCameraUsageDescription</key>
	<string>CyberOS uses your camera so your team can see you during video calls.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CyberOS needs access to your photos so you can attach them to a message.</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
