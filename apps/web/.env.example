# Copied/written by `npx foglamp login` at the monorepo root (preferred) or here.
FOGLAMP_API_KEY=
# Optional override when self-hosting Foglamp ingest:
# FOGLAMP_INGEST_URL=http://localhost:4000/ingest

# Required for local Vite AI middleware (same var the Rust chat service uses).
AI_GATEWAY_URL=http://127.0.0.1:8080

# Optional override for the chat service the middleware loads transcripts from.
# CHAT_URL=http://127.0.0.1:7720
