{
  "name": "@cyberos/chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'TODO: wire eslint'",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@cyberos/db": "workspace:*",
    "@cyberos/events": "workspace:*",
    "@cyberos/mcp-server": "workspace:*",
    "@cyberos/observability": "workspace:*",
    "@cyberos/shared": "workspace:*",
    "@cyberos/subgraph-kit": "workspace:*",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
