{
  "name": "@cyberos/root",
  "private": true,
  "version": "0.1.0",
  "description": "CyberOS — AI-native modular internal operations platform. Monorepo root.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.12.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "gen:features": "tsx scripts/gen-features.ts",
    "gen:roadmap": "tsx scripts/gen-roadmap.ts",
    "gen:module": "tsx scripts/gen-module.ts",
    "validate:fr": "tsx scripts/validate-fr.ts docs/feature-requests",
    "validate:yaml": "tsx scripts/validate-fr.ts --yaml-only",
    "validate:templates": "cyberskill validate docs/feature-requests docs/templates",
    "validate:modules": "tsx scripts/validate-modules.ts",
    "validate:all": "pnpm validate:yaml && pnpm validate:fr && pnpm validate:modules"
  },
  "devDependencies": {
    "@cyberskill/templates": "1.0.0",
    "@types/node": "^20.14.0",
    "lefthook": "^1.7.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "yaml": "^2.6.0"
  }
}
