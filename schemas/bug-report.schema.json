{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberskill.dev/schemas/bug-report.schema.json",
  "title": "CyberSkill Bug Report Template — bug_report@1",
  "description": "Schema for the bug report template's YAML frontmatter. Encodes the PDPL Article 23 conditional from audit §1.4 #3: when pdpl_breach_suspected=true, discovered_at becomes required (the validator additionally asserts ## Breach Containment and ## Notification Plan H2 sections).",
  "type": "object",
  "propertyNames": {
    "pattern": "^[a-z][a-z0-9_]*$"
  },
  "additionalProperties": false,
  "allOf": [
    { "$ref": "common.schema.json#/$defs/common_header" },
    {
      "required": [
        "severity",
        "affected_versions",
        "pdpl_breach_suspected",
        "reproducible"
      ],
      "properties": {
        "title": true,
        "author": true,
        "department": true,
        "status": true,
        "priority": true,
        "created_at": true,
        "ai_authorship": true,
        "template": {
          "const": "bug_report@1"
        },
        "severity": {
          "type": "string",
          "enum": ["sev1", "sev2", "sev3", "sev4"],
          "description": "Customer-impact severity, distinct from priority."
        },
        "affected_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "SemVer ranges (e.g. >=1.2.0 <1.3.0)."
        },
        "pdpl_breach_suspected": {
          "type": "boolean",
          "description": "Vietnam PDPL Article 23: notification within 72 hours of discovery. If true, discovered_at must be set and the body must contain ## Breach Containment and ## Notification Plan H2 sections."
        },
        "discovered_at": {
          "$ref": "common.schema.json#/$defs/iso_datetime",
          "description": "ISO 8601 with timezone. Required when pdpl_breach_suspected=true (clock start for the 72-hour window)."
        },
        "reproducible": {
          "type": "string",
          "enum": ["always", "intermittent", "once", "unable_to_reproduce"]
        }
      },
      "if": {
        "properties": {
          "pdpl_breach_suspected": { "const": true }
        },
        "required": ["pdpl_breach_suspected"]
      },
      "then": {
        "required": ["discovered_at"]
      }
    }
  ]
}
