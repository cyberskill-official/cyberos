{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberskill.dev/schemas/common.schema.json",
  "title": "CyberSkill Templates — Common Header",
  "description": "Frontmatter fields shared across pull-request, bug-report, and feature-request templates. Referenced by the three per-template schemas via $ref. Source of truth for the eight common header fields locked in audit §1.3.",
  "type": "object",
  "propertyNames": {
    "pattern": "^[a-z][a-z0-9_]*$",
    "description": "All keys must be snake_case. Enforced as a hard error per audit §1.2 (P0 #3)."
  },
  "$defs": {
    "department": {
      "type": "string",
      "enum": [
        "engineering",
        "design",
        "product",
        "sales",
        "operations",
        "hr",
        "client_success"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_review",
        "in_review",
        "approved",
        "merged",
        "closed"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["p0", "p1", "p2", "p3"],
      "description": "Work-order priority. p0 = production-down, p3 = nice-to-have. Distinct from severity (which measures customer impact)."
    },
    "ai_authorship": {
      "type": "string",
      "enum": ["none", "assisted", "co_authored", "generated_then_reviewed"]
    },
    "iso_date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "iso_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "github_handle": {
      "type": "string",
      "pattern": "^@[A-Za-z0-9]([A-Za-z0-9-]{0,38}[A-Za-z0-9])?$",
      "description": "GitHub handle with leading @. Length and character rules match GitHub's username constraints."
    },
    "issue_ref": {
      "type": "string",
      "pattern": "^(?:[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)?#[0-9]+$"
    },
    "common_header": {
      "type": "object",
      "required": [
        "title",
        "author",
        "department",
        "status",
        "priority",
        "created_at",
        "ai_authorship",
        "template"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 72,
          "description": "Conventional Commits subject for PRs; <= 72 characters."
        },
        "author": {
          "$ref": "#/$defs/github_handle"
        },
        "department": {
          "$ref": "#/$defs/department"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "created_at": {
          "$ref": "#/$defs/iso_date"
        },
        "ai_authorship": {
          "$ref": "#/$defs/ai_authorship"
        },
        "template": {
          "type": "string",
          "description": "Template identity tag. The validator reads this to pick the schema. Renamed from schema_version per audit §1.1.",
          "enum": [
            "pull_request@1",
            "bug_report@1",
            "feature_request@1"
          ]
        }
      }
    }
  }
}
