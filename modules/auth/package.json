{
  "name": "@cyberos/auth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apollo/subgraph": "^2.9.0",
    "@prisma/client": "^6.0.0",
    "apollo-server-express": "^3.13.0",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "jose": "^5.9.0",
    "nats": "^2.28.0",
    "pino": "^9.5.0",
    "newrelic": "^12.0.0",
    "@newrelic/apollo-server-plugin": "^3.0.0",
    "@modelcontextprotocol/sdk": "^2.0.0"
  },
  "devDependencies": {
    "@cyberos/config-tsconfig": "workspace:*",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
