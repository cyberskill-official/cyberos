<?xml version="1.0" encoding="utf-8"?>
<!--
  vn-vat-invoice — XML template skeleton (HUMAN REFERENCE ONLY).

  The generator at ../scripts/generate_invoice.py builds the tree
  programmatically. This template exists so a human can eyeball the
  shape without running the script. Do NOT load this file from
  generator code — it would defeat the deterministic build path.

  Placeholders: {{Field}}
-->
<Invoice xmlns:inv="http://kekhaithue.gdt.gov.vn/TIN/2014/04/01/HoaDonDienTu" xmlns:ds="http://www.w3.org/2000/09/xmldsig#">
  <Header>
    <InvoiceNo>{{invoice_no}}</InvoiceNo>
    <InvoiceDate>{{invoice_date}}</InvoiceDate>
    <Currency>{{currency}}</Currency>
    <PaymentMethod>{{payment_method}}</PaymentMethod>
  </Header>
  <Seller>
    <Name>{{seller.name}}</Name>
    <MST>{{seller.mst}}</MST>
    <Address>{{seller.address}}</Address>
  </Seller>
  <Buyer>
    <Name>{{buyer.name}}</Name>
    <MST>{{buyer.mst}}</MST>
    <Address>{{buyer.address}}</Address>
  </Buyer>
  <Lines>
    <!-- repeat <Line> per item -->
    <Line index="{{i}}">
      <Name>{{line.name}}</Name>
      <Unit>{{line.unit}}</Unit>
      <Qty>{{line.qty}}</Qty>
      <UnitPrice>{{line.unit_price}}</UnitPrice>
      <Amount>{{line.amount}}</Amount>
      <VatRate>{{line.vat_rate}}</VatRate>
      <VatAmount>{{line.vat_amount}}</VatAmount>
    </Line>
  </Lines>
  <Totals>
    <TotalAmount>{{totals.amount}}</TotalAmount>
    <TotalVat>{{totals.vat}}</TotalVat>
    <GrandTotal>{{totals.grand}}</GrandTotal>
  </Totals>
</Invoice>
