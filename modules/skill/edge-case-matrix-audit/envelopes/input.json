{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cyberos.skill.edge-case-matrix-audit.input/v1",
  "title": "edge-case-matrix-audit input envelope",
  "type": "object",
  "required": [
    "artefact_paths"
  ],
  "additionalProperties": false,
  "properties": {
    "artefact_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rubric_version": {
      "type": "string",
      "default": "edge_case_matrix_rubric@1.0"
    },
    "trace_id": {
      "type": "string"
    },
    "max_iterations_per_artefact": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 10
    }
  }
}
