def _cmd_status_security(args):
    """Aspect 5.4 — encryption posture audit."""
    root = find_brain_root()
    brain = root / ".cyberos-memory"
    enc_tool = root / "runtime" / "tools" / "cyberos_encrypt.py"

    print()
    print(_c("═" * 64, "36"))
    print(f"  {BOLD('Security posture audit')} — Aspect 5.4")
    print(_c("═" * 64, "36"))
    print()

    # 1. Encryption status via cyberos_encrypt.py
    if enc_tool.exists():
        try:
            out = subprocess.run(["python3", str(enc_tool), str(brain), "status"],
                                 capture_output=True, text=True, timeout=10)
            if out.returncode == 0 and out.stdout.strip():
                try:
                    sec = json.loads(out.stdout)
                    enabled = sec.get("policy_enabled", False)
                    enc_count = sec.get("memories_encrypted", 0)
                    plain_count = sec.get("memories_plaintext", 0)
                    label = OK("ENABLED") if enabled else WARN("DISABLED")
                    print(f"  {BOLD('§5.6 encryption')} {label}")
                    if enabled:
                        print(f"               algorithm:    {sec.get('policy_algorithm', '?')}")
                        print(f"               kdf:          {sec.get('policy_key_derivation', '?')}")
                        print(f"               scopes:       {', '.join(sec.get('policy_scopes', []) or [])}")
                    print(f"               encrypted:    {enc_count}")
                    print(f"               plaintext:    {plain_count}")
                    if sec.get("shamir_threshold"):
                        print(f"               shamir:       {sec.get('shamir_threshold')}-of-{sec.get('shamir_total')} "
                              f"({sec.get('shamir_fragments_distributed', 0)} fragments distributed)")
                except json.JSONDecodeError:
                    print(f"  {WARN('encrypt status non-JSON')} — see `cyberos_encrypt.py status` directly")
            else:
                print(f"  {WARN('encrypt status failed:')} {out.stderr.strip()[:80]}")
        except Exception as e:
            print(f"  {WARN(f'encrypt status error: {e}')}")
    else:
        print(f"  {WARN('cyberos_encrypt.py not found')}")
    print()

    # 2. Denylist regression suite
    denylist_test = root / "runtime" / "tests" / "denylist" / "test_denylist.py"
    if denylist_test.exists():
        try:
            out = subprocess.run(["python3", str(denylist_test)],
                                 capture_output=True, text=True, timeout=15)
            label = OK("PASS") if out.returncode == 0 else CRIT(f"FAIL rc={out.returncode}")
            print(f"  {BOLD('§9.3 denylist test')} {label}")
            # Surface last 2 lines of stdout for context
            for line in out.stdout.strip().splitlines()[-3:]:
                print(f"               {line}")
        except Exception as e:
            print(f"  {WARN(f'denylist test error: {e}')}")
    print()

    # 3. Filesystem permission audit
    print(f"  {BOLD('Filesystem permissions')}")
    sensitive = [
        brain / "manifest.json",
        brain / "audit",
        root / "outputs" / "staged-memories",
    ]
    for p in sensitive:
        if not p.exists():
            continue
        try:
            import stat as _stat
            mode = p.stat().st_mode
            perms = _stat.filemode(mode)
            # Flag world-readable/writable on sensitive paths
            world_w = bool(mode & 0o002)
            world_r = bool(mode & 0o004)
            flag = ""
            if world_w:
                flag = CRIT(" world-WRITABLE")
            elif world_r:
                flag = WARN(" world-readable")
            rel = p.relative_to(root)
            print(f"    {perms}  {rel}{flag}")
        except Exception:
            continue
    print()

    # 4. Recent PANIC + drift
    panic_marker = brain / "meta" / "PANIC.md"
    panic_active = False
    if panic_marker.exists():
        try:
            ptext = panic_marker.read_text(encoding="utf-8")
            # Resolved markers carry "(resolved)" in the title — treat as inactive.
            panic_active = "(resolved)" not in ptext.splitlines()[0]
        except Exception:
            panic_active = True
    panic_label = CRIT("ACTIVE") if panic_active else OK("inactive")
    print(f"  {BOLD('§13.10 PANIC mode')}  {panic_label}")
    drift_dir = brain / "memories" / "drift"
    drift_n = sum(1 for _ in drift_dir.glob("*.md")) if drift_dir.exists() else 0
    drift_label = OK(f"{drift_n} unresolved") if drift_n == 0 else WARN(f"{drift_n} unresolved")
    print(f"  {BOLD('§8.6 drift candidates')} {drift_label}")
    print()
    print(_c("═" * 64, "36"))
    return 0


def _cmd_status_dashboard(args):
    """4-operator-question dashboard per Aspect 2.1."""
    root = find_brain_root()
    brain = root / ".cyberos-memory"
    manifest_p = brain / "manifest.json"
    if not manifest_p.exists():
        print(CRIT("ERROR:") + f" {manifest_p} not found", file=sys.stderr)
        sys.exit(2)
    try:
        manifest = json.loads(manifest_p.read_text())
    except Exception as e:
        print(CRIT("ERROR:") + f" failed to parse manifest.json: {e}", file=sys.stderr)
        sys.exit(2)

    # ---- Header ----
    project_name = manifest.get("project", {}).get("name", "<unknown>")
    project_id = manifest.get("project", {}).get("id", "<unknown>")
    memory_count = manifest.get("memory_count", "?")
    # Real on-disk count (audit divergence signal)
    real_count = sum(1 for _ in brain.rglob("*.md") if _.is_file() and not _.name.startswith("."))
    audit_head = manifest.get("audit_chain_head", "?")[:16] + "…"
    last_updated = manifest.get("last_updated_at", "?")

    print()
    print(_c("═" * 64, "36"))
    print(f"  {BOLD('CyberOS BRAIN Status')} — {project_name}")
    print(f"  {DIM(f'project: {project_id}    memory: {real_count} files (manifest: {memory_count})')}")
    print(_c("═" * 64, "36"))
    print()

    # ---- Q1: HEALTHY? ----
    findings = _collect_findings(root, brain)
    crit = [f for f in findings if f["severity"] == "CRITICAL"]
    warn = [f for f in findings if f["severity"] == "WARN"]
    info_n = len([f for f in findings if f["severity"] == "INFO"])

    if crit:
        healthy_label = CRIT("✗ FAILED")
        healthy_summary = f"{len(crit)} CRITICAL / {len(warn)} WARN"
    elif warn:
        healthy_label = WARN("⚠ DEGRADED")
        healthy_summary = f"0 CRITICAL / {len(warn)} WARN"
    else:
        healthy_label = OK("✓ CLEAR")
        healthy_summary = f"0 CRITICAL / 0 WARN / {info_n} INFO"

    pin_status = OK("✓") if _verify_pin(root, manifest) else CRIT("✗")
    print(f"  {BOLD('HEALTHY?')}    {healthy_label}")
    print(f"               {healthy_summary}")
    print(f"               Protocol pin: {pin_status} {manifest.get('protocol', {}).get('sha256', '?')[:24]}…")
    print(f"               Audit head:   {audit_head}")
    print(f"               Last update:  {DIM(last_updated)}")
    print()

    # ---- Q2: BOTTLENECK? ----
    bottlenecks = _find_bottlenecks(brain)
    if bottlenecks:
        print(f"  {BOLD('BOTTLENECK?')} {WARN(f'{len(bottlenecks)} items')}")
        for b in bottlenecks[:5]:
            print(f"               · {b}")
    else:
        print(f"  {BOLD('BOTTLENECK?')} {OK('none detected')}")
    print()

    # ---- Q2.5: TRENDS (Aspect 2.2) ----
    trends = _compute_trends(brain)
    if trends:
        print(f"  {BOLD('TRENDS')}      30-day rolling")
        for line in trends:
            print(f"               {line}")
        print()

    # ---- Q3: CHANGED? ----
    changes = _what_changed(brain)
    print(f"  {BOLD('CHANGED?')}    {changes['summary']}")
    for line in changes["lines"][:6]:
        print(f"               {line}")
    print()

    # ---- Q4: WHAT NOW? ----
    actions = _recommend_actions(findings, bottlenecks, brain)
    print(f"  {BOLD('WHAT NOW?')}   {DIM('next 3 actions')}")
    for i, a in enumerate(actions[:3], 1):
        print(f"               {i}. {a}")
    if not actions:
        print(f"               {OK('all clear — nothing immediate')}")
    print()

    print(_c("═" * 64, "36"))
    if args.verbose:
        print(BOLD("\nFull findings:"))
        for f in findings:
            sev_func = {"CRITICAL": CRIT, "WARN": WARN, "INFO": DIM}.get(f["severity"], DIM)
            print(f"  {sev_func(f['severity'])} {f['message']}")

    # Exit code: 0 if CLEAR, 1 if DEGRADED, 2 if FAILED
    if crit:
        sys.exit(2)
    elif warn:
        sys.exit(1)
    else:
        sys.exit(0)

