# ---- ANSI colour (graceful on non-TTY) ----
def _tty():
    return sys.stdout.isatty() and os.environ.get("TERM") not in ("dumb", "")

def _c(text, code):
    if not _tty() or os.environ.get("NO_COLOR"):
        return text
    return f"\033[{code}m{text}\033[0m"

OK = lambda s: _c(s, "32")       # green
WARN = lambda s: _c(s, "33")     # yellow
CRIT = lambda s: _c(s, "31")     # red
DIM = lambda s: _c(s, "2")       # dim
BOLD = lambda s: _c(s, "1")      # bold

# ---- Project root resolution per §0.1 ----
def find_brain_root(start: Path = None) -> Path:
    """Walk up from `start` (default CWD) looking for `.cyberos-memory/`."""
    cur = (start or Path.cwd()).resolve()
    while cur != cur.parent:
        if (cur / ".cyberos-memory").is_dir():
            return cur
        cur = cur.parent
    print(CRIT("ERROR:") + " no .cyberos-memory/ found in CWD or any ancestor", file=sys.stderr)
    print("       Run `cyberos onboard` to bootstrap a new BRAIN, or cd into a project root", file=sys.stderr)
    sys.exit(2)

