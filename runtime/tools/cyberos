def _verify_pin(root: Path, manifest: dict) -> bool:
    """Verify loaded AGENTS.md SHA matches manifest pin per §0.5."""
    loaded_path = manifest.get("protocol", {}).get("loaded_path")
    pinned_sha = manifest.get("protocol", {}).get("sha256")
    if not loaded_path or not pinned_sha:
        return False
    canon_tool = root / "runtime" / "tools" / "canonical_sha.py"
    target = root / loaded_path
    if not canon_tool.exists() or not target.exists():
        return False
    try:
        out = subprocess.check_output(["python3", str(canon_tool), str(target)], text=True).strip()
        # canonical_sha.py outputs the SHA — match against pin
        return pinned_sha in out
    except Exception:
        return False

def _collect_findings(root: Path, brain: Path) -> list:
    """Run cyberos_validate.py and parse findings. Returns list of {severity, message}."""
    tool = root / "runtime" / "tools" / "cyberos_validate.py"
    if not tool.exists():
        return [{"severity": "WARN", "message": "cyberos_validate.py not found — cannot run full validation"}]
    try:
        result = subprocess.run(["python3", str(tool), str(root)], capture_output=True, text=True, timeout=30)
        findings = []
        for line in (result.stdout + result.stderr).split("\n"):
            line = line.strip()
            if not line:
                continue
            # Parse "[CRITICAL]" / "[WARN]" / "[INFO]" lines from validator output
            m = re.match(r"^\[?(CRITICAL|WARN|INFO|ERROR|✓|✗)\]?\s+(.+)$", line)
            if m:
                sev = m.group(1)
                if sev == "ERROR":
                    sev = "CRITICAL"
                if sev in ("✓",):
                    sev = "INFO"
                if sev == "✗":
                    sev = "CRITICAL"
                findings.append({"severity": sev, "message": m.group(2)[:120]})
        return findings
    except subprocess.TimeoutExpired:
        return [{"severity": "WARN", "message": "validator timed out at 30s — store may be very large"}]
    except Exception as e:
        return [{"severity": "WARN", "message": f"validator invocation failed: {e}"}]

def _find_bottlenecks(brain: Path) -> list:
    """Detect: oversize files, near-cap buckets, stale drift candidates."""
    bottlenecks = []
    BODY_HARD_KB = 30
    BUCKET_SOFT_LIMIT = 100  # split threshold

    # Size-cap-exempt paths per AGENTS.md §0.5 step 1 (verbatim protocol-doc archives)
    # and §3 (audit ledger is a different class) and §6 (manifest has its own caps)
    SIZE_EXEMPT = (
        "meta/protocol-history/AGENTS-",  # §0.5 step 1
        "audit/",                          # ledger; separate caps in §5.5
        "manifest.json",                   # 4 KB cap per §5.5 — handled elsewhere
        "exports/",                        # local zips
        "index/",                          # SQLite — separate
        "__pycache__/",                    # Python build artifacts
    )

    for f in brain.rglob("*.md"):
        if not f.is_file() or f.name.startswith("."):
            continue
        rel_str = str(f.relative_to(brain))
        if any(rel_str.startswith(ex) for ex in SIZE_EXEMPT):
            continue
        size = f.stat().st_size
        if size > BODY_HARD_KB * 1024:
            rel = f.relative_to(brain)
            bottlenecks.append(f"{rel} ({size // 1024} KB — over {BODY_HARD_KB} KB cap)")
        elif size > int(BODY_HARD_KB * 0.9 * 1024):
            rel = f.relative_to(brain)
            bottlenecks.append(f"{rel} ({size // 1024} KB — near cap)")

    # Bucket overflow
    for d in (brain / "memories").iterdir() if (brain / "memories").exists() else []:
        if d.is_dir():
            n = sum(1 for _ in d.glob("*.md"))
            if n >= BUCKET_SOFT_LIMIT:
                bottlenecks.append(f"memories/{d.name}/ has {n} entries (split threshold @ {BUCKET_SOFT_LIMIT})")

    # Manifest count drift (a real bug signal — manifest out of sync with disk)
    # Done by passing manifest_count via closure-like state. Recompute here for simplicity:
    manifest_p = brain / "manifest.json"
    if manifest_p.exists():
        try:
            mc = json.loads(manifest_p.read_text()).get("memory_count", 0)
            real = sum(1 for _ in brain.rglob("*.md") if _.is_file() and not _.name.startswith("."))
            if mc != real:
                bottlenecks.append(f"manifest.memory_count={mc} but {real} files on disk (drift={real-mc}) — run cyberos verify")
        except Exception:
            pass

    # Drift candidates
    drift = brain / "memories" / "drift"
    if drift.exists():
        n = sum(1 for _ in drift.glob("*.md"))
        if n > 0:
            # Find oldest by name (YYYY-MM-DD prefix)
            files = sorted(drift.glob("*.md"))
            oldest_age_str = "unknown"
            if files:
                m = re.match(r"^(\d{4}-\d{2}-\d{2})", files[0].name)
                if m:
                    try:
                        d = datetime.strptime(m.group(1), "%Y-%m-%d")
                        days = (datetime.now() - d).days
                        oldest_age_str = f"{days} days"
                    except Exception:
                        pass
                bottlenecks.append(f"{n} drift candidates unresolved (oldest: {oldest_age_str})")

    return bottlenecks

def _compute_trends(brain: Path) -> list:
    """Aspect 2.2 — 30-day rolling deltas: memory_count, audit-op-rate, drift-candidate count."""
    out = []
    now = datetime.now(ICT)
    cutoff = now - timedelta(days=30)
    audit_dir = brain / "audit"
    if not audit_dir.exists():
        return out

    # Memory writes in last 30d
    creates = 0
    str_replaces = 0
    deletes = 0
    rows_30d = 0
    for ledger in sorted(audit_dir.glob("*.jsonl")):
        for line in ledger.read_text(encoding="utf-8", errors="ignore").splitlines():
            if not line.strip():
                continue
            try:
                r = json.loads(line)
                ts = datetime.fromisoformat(r.get("ts", ""))
                if ts < cutoff:
                    continue
                rows_30d += 1
                op = r.get("op", "")
                if op == "create": creates += 1
                elif op == "str_replace": str_replaces += 1
                elif op in ("delete", "tombstone"): deletes += 1
            except Exception:
                continue

    if creates or str_replaces or deletes:
        net = creates - deletes
        arrow = OK("↑") if net > 0 else (CRIT("↓") if net < 0 else DIM("·"))
        out.append(f"{arrow} memory net +{net:>+4d}  (creates={creates}  edits={str_replaces}  deletes={deletes})")
    if rows_30d:
        per_day = rows_30d / 30
        out.append(f"  audit ops      {rows_30d:>4d} total  ({per_day:.1f}/day avg)")

    # Drift candidates trend
    drift_dir = brain / "memories" / "drift"
    if drift_dir.exists():
        recent = 0
        for d in drift_dir.glob("*.md"):
            try:
                mtime = datetime.fromtimestamp(d.stat().st_mtime, tz=ICT)
                if mtime >= cutoff:
                    recent += 1
            except Exception:
                continue
        if recent:
            out.append(f"  drift surfaced {recent:>4d} in 30d")

    return out


def _what_changed(brain: Path) -> dict:
    """Detect changes since last manifest update (proxy for 'last status check')."""
    lines = []
    # Walk audit ledger for current month
    audit_dir = brain / "audit"
    if not audit_dir.exists():
        return {"summary": DIM("no audit history"), "lines": []}

    now = datetime.now(ICT)
    cur_ledger = audit_dir / f"{now.year}-{now.month:02d}.jsonl"
    if not cur_ledger.exists():
        return {"summary": DIM("no current-month audit ledger"), "lines": []}

    op_counts = {}
    session_count = 0
    last_24h = now - timedelta(hours=24)

    for line in cur_ledger.read_text().split("\n"):
        if not line.strip():
            continue
        try:
            row = json.loads(line)
        except Exception:
            continue
        ts_str = row.get("ts", "")
        try:
            ts = datetime.fromisoformat(ts_str)
            if ts < last_24h:
                continue
        except Exception:
            continue
        op = row.get("op", "?")
        op_counts[op] = op_counts.get(op, 0) + 1
        if op == "session.start":
            session_count += 1

    if not op_counts:
        return {"summary": DIM("no activity in last 24h"), "lines": []}

    total = sum(v for k, v in op_counts.items() if k not in ("session.start", "session.end", "manifest_update"))
    summary = f"{total} operations in last 24h ({session_count} session{'s' if session_count != 1 else ''})"

    for op, n in sorted(op_counts.items(), key=lambda x: -x[1]):
        if op in ("session.start", "session.end"):
            continue
        marker = OK("+") if op in ("create", "insert") else (CRIT("·") if op == "delete" else DIM("·"))
        lines.append(f"{marker} {n:3d} {op}")

    return {"summary": summary, "lines": lines}

def _recommend_actions(findings, bottlenecks, brain) -> list:
    """Surface 3 next-actions based on findings + bottlenecks."""
    actions = []

    # Critical findings always first
    crit = [f for f in findings if f["severity"] == "CRITICAL"]
    if crit:
        actions.append(f"Resolve {len(crit)} CRITICAL: " + CRIT("cyberos verify --verbose"))

    # Bottlenecks
    for b in bottlenecks[:2]:
        if "over" in b and "KB cap" in b:
            actions.append(f"Split oversize file: {DIM(b.split(' (')[0])} via §8.4 reorganise")
        elif "drift candidates" in b:
            actions.append(f"Review drift: {DIM('cyberos prune --drift')} (not yet implemented — manual: ls memories/drift/)")
        elif "split threshold" in b:
            actions.append(f"Reorganise bucket: {DIM(b.split(' has')[0])} per §8.4")

    # Underused buckets (Aspect 4.2)
    for b in ("memories/facts", "memories/people"):
        d = brain / b
        if not d.exists() or sum(1 for _ in d.glob("*.md")) == 0:
            actions.append(f"Start using underused bucket: {DIM(b + '/')} (Aspect 4.3)")
            break  # only surface one underused-bucket nudge at a time

    # Pad with INFO-level if we have <3 actions
    info = [f for f in findings if f["severity"] == "INFO"]
    while len(actions) < 3 and info:
        f = info.pop(0)
        actions.append(f"Review INFO: {DIM(f['message'][:60])}")

    return actions[:3]

# ---- Aspect 2.3: --weekly digest ----

def _cmd_status_weekly(args):
    """Weekly digest — landed / in-flight / queued framing per gstack /landing-report."""
    root = find_brain_root()
    brain = root / ".cyberos-memory"
    audit_dir = brain / "audit"
    if not audit_dir.exists():
        print(WARN("no audit history"))
        return 1

    now = datetime.now(ICT)
    week_ago = now - timedelta(days=7)

    # Collect audit rows from the last 7 days (handle month boundary)
    rows = []
    for ledger in sorted(audit_dir.glob("*.jsonl")):
        for line in ledger.read_text().splitlines():
            if not line.strip():
                continue
            try:
                row = json.loads(line)
                ts = datetime.fromisoformat(row.get("ts", ""))
                if ts >= week_ago:
                    rows.append(row)
            except Exception:
                continue

    # Bucket by intent
    landed = []   # successful create / str_replace / rename / delete
    in_flight = []  # uncommitted: drift candidates, staged files, open refinements
    queued = []   # candidates: rejected/, postmortems/, drift candidates without resolution

    op_to_label = {
        "create": "landed",
        "str_replace": "landed",
        "rename": "landed",
        "delete": "landed",
        "tombstone": "landed",
    }
    for row in rows:
        op = row.get("op", "")
        if op_to_label.get(op) == "landed":
            landed.append(row)

    # in-flight: staged-memories/ count
    staged_dir = root / "outputs" / "staged-memories"
    if staged_dir.exists():
        for s in staged_dir.glob("*.md"):
            in_flight.append({"path": str(s.relative_to(root)), "kind": "staged"})

    # queued: drift candidates + open council sessions
    drift_dir = brain / "memories" / "drift"
    if drift_dir.exists():
        for d in drift_dir.glob("*.md"):
            queued.append({"path": str(d.relative_to(brain)), "kind": "drift-candidate"})
    council_dir = root / "outputs" / "council"
    if council_dir.exists():
        for c in council_dir.glob("REF-*-council.md"):
            queued.append({"path": str(c.relative_to(root)), "kind": "council-pending"})

    print()
    print(_c("═" * 64, "36"))
    print(f"  {BOLD('BRAIN weekly digest')} — {week_ago.strftime('%Y-%m-%d')} → {now.strftime('%Y-%m-%d')}")
    print(_c("═" * 64, "36"))
    print()
    print(f"  {OK('LANDED')}     {len(landed)} audit operations recorded")
    op_breakdown = {}
    for r in landed:
        op = r.get("op", "?")
        op_breakdown[op] = op_breakdown.get(op, 0) + 1
    for op, n in sorted(op_breakdown.items(), key=lambda x: -x[1])[:5]:
        print(f"             · {n:3d} {op}")
    print()
    print(f"  {WARN('IN-FLIGHT')}  {len(in_flight)} staged but not yet written")
    for x in in_flight[:5]:
        print(f"             · {x['path']}  ({x['kind']})")
    if len(in_flight) > 5:
        print(f"             … +{len(in_flight) - 5} more")
    print()
    print(f"  {DIM('QUEUED')}     {len(queued)} items awaiting attention")
    for x in queued[:5]:
        print(f"             · {x['path']}  ({x['kind']})")
    if len(queued) > 5:
        print(f"             … +{len(queued) - 5} more")
    print()
    print(_c("═" * 64, "36"))
    return 0


# ---- Aspect 2.4: --watch continuous ----

def _cmd_status_watch(args):
    """Continuous mode — re-render the dashboard every N seconds (default 30)."""
    import time as _time
    interval = max(5, int(getattr(args, "interval", 30) or 30))
    print(f"  cyberos status --watch (interval={interval}s) — Ctrl-C to exit")
    try:
        while True:
            # Clear screen (ANSI)
            sys.stdout.write("\033[2J\033[H")
            sys.stdout.flush()
            # Suppress sys.exit from dashboard by catching SystemExit
            args.weekly = False
            args.watch = False
            try:
                _cmd_status_dashboard(args)
            except SystemExit:
                pass
            print(f"\n  {DIM(f'next refresh in {interval}s — Ctrl-C to exit')}")
            _time.sleep(interval)
    except KeyboardInterrupt:
        print(f"\n  watch stopped.")
        return 0

