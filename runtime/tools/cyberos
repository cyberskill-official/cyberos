def cmd_stats(args):
    """Counts by bucket / classification / authority / sync-class."""
    root = find_brain_root()
    brain = root / ".cyberos-memory"

    buckets = ["company", "module", "member", "client", "project", "persona", "meta"]
    memories_buckets = ["decisions", "refinements", "facts", "people", "projects", "preferences", "drift"]

    counts = {}
    for b in buckets:
        d = brain / b
        if d.exists():
            counts[b] = sum(1 for _ in d.rglob("*.md") if _.is_file())
        else:
            counts[b] = 0

    mem_counts = {}
    for b in memories_buckets:
        d = brain / "memories" / b
        if d.exists():
            mem_counts[b] = sum(1 for _ in d.rglob("*.md") if _.is_file())
        else:
            mem_counts[b] = 0

    print(BOLD("Memory by scope:"))
    for b, c in sorted(counts.items(), key=lambda x: -x[1]):
        marker = ""
        if c == 0:
            marker = DIM("  ☆ never used")
        print(f"  {b:12s}: {c:4d}{marker}")
    print()
    print(BOLD("Memory by memories/ bucket:"))
    for b, c in sorted(mem_counts.items(), key=lambda x: -x[1]):
        marker = ""
        if c == 0:
            marker = DIM("  ☆ never used")
        print(f"  {b:12s}: {c:4d}{marker}")

    total = sum(counts.values()) + sum(mem_counts.values())
    print()
    print(BOLD(f"Total: {total} memories"))

def _encryption_posture(brain: Path) -> dict:
    """Aspect 5.4 — surface encryption posture."""
    manifest_p = brain / "manifest.json"
    if not manifest_p.exists():
        return {"enabled": False, "info": "no manifest"}
    try:
        m = json.loads(manifest_p.read_text())
        enc = m.get("encryption_policy", {})
        shamir = m.get("shamir_fragments", {})
        encrypted_n = 0
        for f in brain.rglob("*.md"):
            if not f.is_file() or f.name.startswith("."):
                continue
            try:
                head = f.read_text(errors="replace")[:2000]
                if "encrypted: true" in head:
                    encrypted_n += 1
            except Exception:
                pass
        return {
            "enabled": enc.get("enabled", False),
            "algorithm": enc.get("algorithm"),
            "encrypted_n": encrypted_n,
            "shamir_threshold": shamir.get("threshold"),
            "shamir_total": shamir.get("total"),
            "fragments_configured": len(shamir.get("fragments", [])),
            "master_key_fingerprint": shamir.get("master_key_fingerprint"),
        }
    except Exception as e:
        return {"enabled": False, "info": f"error: {e}"}

def _drift_summary(brain: Path) -> list[str]:
    """Aspect 11.3 — drift candidate summary."""
    drift = brain / "memories" / "drift"
    if not drift.exists():
        return []
    out = []
    files = sorted(drift.glob("*.md"))
    for f in files[:5]:
        out.append(f.name[:60])
    if len(files) > 5:
        out.append(f"... and {len(files) - 5} more")
    return out

