def cmd_panic(args):
    """Emergency stop — freeze all writes pending review. Aspect 13.10."""
    root = find_brain_root()
    brain = root / ".cyberos-memory"
    panic_marker = brain / "meta" / "PANIC.md"
    if args.resolve:
        if not panic_marker.exists():
            print(WARN("no PANIC mode active"))
            return
        try:
            panic_marker.unlink()
        except PermissionError as e:
            print(WARN(f"could not unlink PANIC marker (sandbox or perms): {e}"))
            print(f"  Manually delete: rm {panic_marker}")
            return
        print(OK("PANIC mode cleared. Writes re-enabled."))
        print(f"  Reason recorded: {args.resolve}")
        return
    if panic_marker.exists():
        print(WARN("PANIC mode already active. Use --resolve <reason> to clear."))
        print(panic_marker.read_text())
        return
    reason = args.reason or input("Why are you entering PANIC mode? ")
    ts = datetime.now(ICT).isoformat(timespec='seconds')
    panic_marker.parent.mkdir(parents=True, exist_ok=True)
    panic_marker.write_text(f"""# PANIC mode active

**Entered:** {ts}
**Reason:** {reason}

All writes are frozen. Subsequent sessions will detect this file and refuse writes
until cleared via:

    cyberos panic --resolve "<resolution note>"

Recommended actions:
1. Run `cyberos export --to ~/cyberos-panic-{ts[:10]}.zip` to snapshot current state
2. Investigate the underlying issue (check audit ledger, recent diffs)
3. Decide: clear PANIC or rollback to a known-good checkpoint

This file is informational; not a memory file; manual creation/deletion only.
""")
    print(CRIT(f"PANIC mode set. Marker: {panic_marker}"))
    print("Run `cyberos export` to snapshot current state.")
    print(f"Clear with: cyberos panic --resolve \"<reason>\"")

def cmd_doc_consistency(args):
    """Cross-doc consistency check per Aspect 7.3."""
    root = find_brain_root()
    docs = root / "docs"
    if not docs.exists():
        print(ERR("no docs/ dir"))
        return 2

    findings = []
    agents = (docs / "CyberOS-AGENTS.md")
    readme = (docs / "CyberOS-AGENTS.README.md")
    changelog = (docs / "CyberOS-AGENTS.CHANGELOG.md")
    core = (docs / "CyberOS-AGENTS-CORE.md")

    if agents.exists() and readme.exists():
        agents_text = agents.read_text()
        readme_text = readme.read_text()
        # Check every §X.Y reference in README exists as anchor in AGENTS
        section_refs = set(re.findall(r"§(\d+(?:\.\d+)*)", readme_text))
        agents_sections = set()
        for m in re.finditer(r"^###?\s+(\d+(?:\.\d+)*)\b", agents_text, re.M):
            agents_sections.add(m.group(1))
        missing = section_refs - agents_sections
        for ref in sorted(missing):
            findings.append(f"README references §{ref} but no such section exists in AGENTS.md")

    # Check every DEC referenced in CHANGELOG exists in memories/decisions/
    if changelog.exists():
        cl_text = changelog.read_text()
        dec_refs = set(re.findall(r"\b(DEC-\d{3})\b", cl_text))
        decisions_dir = root / ".cyberos-memory" / "memories" / "decisions"
        existing_decs = set()
        if decisions_dir.exists():
            for f in decisions_dir.glob("*.md"):
                m = re.match(r"^(DEC-\d{3})", f.name)
                if m:
                    existing_decs.add(m.group(1))
        missing_decs = dec_refs - existing_decs
        for d in sorted(missing_decs):
            findings.append(f"CHANGELOG references {d} but no memories/decisions/{d}-*.md exists")

    if not findings:
        print(OK("✓ doc consistency: no issues"))
        return 0

    print(WARN(f"{len(findings)} consistency issues:"))
    for f in findings:
        print(f"  · {f}")
    return 1 if args.strict else 0

