# Copy to dev.env to override the local bring-up defaults. Dev only; dev.env is gitignored.
# Everything here has a sane default in dev-up.sh, so dev.env is optional.

# Ports / addresses
AUTH_LISTEN_ADDR=0.0.0.0:7700
CHAT_LISTEN_ADDR=127.0.0.1:7720
CONSOLE_PORT=8090

# Auth
AUTH_JWT_ISSUER=http://localhost:7700
AUTH_CURSOR_SIGNING_SECRET=dev-only-cursor-secret-change-me
REDIS_URL=redis://localhost:6379

# Postgres base; the cyberos and cyberos_chat databases hang off this host.
DB_BASE=postgres://cyberos:cyberos@localhost:5432

# Chat verifies access tokens against this auth JWKS URL.
CHAT_AUTH_JWKS_URL=http://127.0.0.1:7700/.well-known/jwks.json

# Demo sign-in (seed-demo-user.sh)
DEMO_TENANT=cyberskill
DEMO_HANDLE=@stephen
DEMO_EMAIL=stephen@cyberskill.world
DEMO_PASSWORD=CyberOS-Demo-2026!
