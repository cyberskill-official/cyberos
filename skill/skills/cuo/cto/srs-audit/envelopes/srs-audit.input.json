{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cto/srs-audit/envelopes/srs-audit.input.json",
  "title": "srs-audit input envelope",
  "type": "object",
  "required": ["srs_paths"],
  "additionalProperties": false,
  "properties": {
    "srs_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "rubric_version": {"type": "string", "pattern": "^srs_rubric@\\d+\\.\\d+$", "default": "srs_rubric@1.0"},
    "upstream_context": {"type": "object"},
    "trace_id": {"type": "string", "format": "uuid"},
    "caller_persona": {"type": "string", "pattern": "^cuo(-[a-z0-9-]+)?$"},
    "max_iterations_per_srs": {"type": "integer", "minimum": 1, "maximum": 20, "default": 5}
  }
}
