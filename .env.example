# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cyberos:cyberos@localhost:5432/cyberos_dev?schema=public"
# Neon connection string (production — set per environment in Doppler)
# DATABASE_URL="postgresql://..."

# ─── AUTH MODULE ─────────────────────────────────────────────────────────────
AUTH_JWT_PRIVATE_KEY_PATH="./keys/rs256_private.pem"
AUTH_JWT_PUBLIC_KEY_PATH="./keys/rs256_public.pem"
AUTH_JWT_EXPIRY="24h"
AUTH_OIDC_ISSUER="https://auth.cyberos.vn"

# ─── AI GATEWAY ──────────────────────────────────────────────────────────────
AI_OPENAI_API_KEY=""
AI_ANTHROPIC_API_KEY=""
AI_EMBEDDING_MODEL="text-embedding-3-small"
AI_EMBEDDING_DIMS="1536"
# Per-tenant LLM budget guardrail (USD/month)
AI_TENANT_BUDGET_USD="50"

# ─── GRAPH ROUTER ────────────────────────────────────────────────────────────
APOLLO_KEY=""
APOLLO_GRAPH_REF="cyberos@current"
ROUTER_PORT="4000"

# ─── NATS (domain events) ────────────────────────────────────────────────────
NATS_URL="nats://localhost:4222"

# ─── REDIS / BULLMQ ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MCP SERVER ──────────────────────────────────────────────────────────────
MCP_PORT="8080"
MCP_BASE_URL="https://mcp.cyberos.vn"

# ─── OBSERVABILITY ───────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=""
NEW_RELIC_APP_NAME="cyberos-local"
LOG_LEVEL="info"

# ─── STORAGE ─────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cyberos-dev"

# ─── EMAIL MODULE ────────────────────────────────────────────────────────────
EMAIL_IMAP_HOST=""
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"

# ─── SECRETS (use Doppler in CI/prod) ────────────────────────────────────────
# Never commit real secrets. All secrets injected at runtime via Doppler.
# doppler run -- pnpm dev
