# CyberOS — environment variables (template).
# Copy to .env (gitignored) for local dev. Production secrets live in Vault.

NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────
# Per-tenant residency clusters override this in production. Local dev = single Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cyberos
PRISMA_DATABASE_URL=${DATABASE_URL}

# ─── Event bus (NATS JetStream) ─────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM=cyberos

# ─── Cache + presence (Redis) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI Gateway ─────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_BEDROCK_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Per-tenant USD monthly cap (FR-AI-004). Override in tenant config.
AI_TENANT_BUDGET_USD=200

# ─── Observability ──────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=cyberos-local
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Auth (DEC-003 RS256 JWT) ───────────────────────────────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_AUDIENCE=cyberos
JWT_ISSUER=https://auth.cyberos.local
JWT_TTL_SECONDS=86400

# ─── MCP server ─────────────────────────────────────────────────────────────
MCP_TRANSPORT=stdio
MCP_PORT=8810

# ─── Subgraph ports (deterministic, see modules.yaml) ───────────────────────
PORT_AUTH=4001
PORT_AI=4002
PORT_MCP=4003
PORT_OBS=4004
PORT_CHAT=4005
PORT_BRAIN=4006
PORT_GENIE=4007
PORT_PROJ=4008
PORT_TIME=4009
PORT_CRM=4010
PORT_KB=4011
PORT_HR=4012
PORT_EMAIL=4013
PORT_REW=4014
PORT_LEARN=4015
PORT_INV=4016
PORT_ESOP=4017
PORT_RES=4018
PORT_OKR=4019
PORT_DOC=4020
PORT_CP=4021

# ─── GraphOS Router ─────────────────────────────────────────────────────────
APOLLO_KEY=
APOLLO_GRAPH_REF=cyberos@dev
ROUTER_PORT=4000

# ─── Module Federation shell ────────────────────────────────────────────────
SHELL_PORT=3000
