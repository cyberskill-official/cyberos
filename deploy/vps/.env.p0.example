# CyberOS P0 deploy env - copy to .env.p0 on the host and replace every placeholder. .env.p0 is
# gitignored (it holds the DB password). The Google client id/secret are NOT here; they go into the IdP
# config row via the admin API (runbook Step 4).

# The single public origin the team uses. CYBEROS_APP_URL must be https://CYBEROS_APP_DOMAIN.
CYBEROS_APP_DOMAIN=os.cyberskill.world
CYBEROS_APP_URL=https://os.cyberskill.world

COMPOSE_PROJECT_NAME=cyberos-p0
CYBEROS_RUST_VERSION=1.88.0
CYBEROS_IMAGE_TAG=local

# Supabase database (managed Postgres). auth and chat share ONE Supabase project - their tables do not
# collide, and neither service auto-migrates, so a single database holds both. Use the SESSION POOLER
# connection string from the Supabase dashboard (Project Settings -> Database -> Connection string ->
# "Session pooler"): it is IPv4 and session-mode, so the per-request tenant scoping and role GUCs behave.
# Do NOT use the transaction pooler (port 6543) - it would drop the session-scoped app.roles setting.
# Format (replace PROJECT-REF, PASSWORD, and REGION with your project's values; keep sslmode=require):
#   postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Both URLs point at the same project/database for P0; split into two projects later if you want isolation.
AUTH_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
CHAT_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# The eval (BRAIN/EVAL governance) service shares the same Supabase project for P0. The eval service reads
# EVAL_DATABASE_URL directly (not DATABASE_URL). Its schema is applied automatically by the deploy-step
# migration (deploy/vps/migrate.sh); /healthz only needs a connection.
EVAL_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# The deploy applies every service's migrations to this database on each push (deploy/vps/migrate.sh, run
# by deploy.sh). It tracks applied files per-service in `_cyberos_migrations`, and BASELINES the
# already-applied services (auth chat) on first run so their live schema is never re-run. Point this at the
# same Supabase session-pooler DB. Override the baseline set with MIGRATE_BASELINE_SERVICES if needed.
MIGRATIONS_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# DEC-2713 — the chat->brain audit link. Point this at the memory module's l1_audit_log database (the same
# Supabase DB in P0) so chat audit rows AND FR-MEMORY-122 interaction-events chain into MEMORY. Empty = chat
# logs events, does not chain them. Required in production once you turn capture on.
CHAT_AUDIT_DATABASE_URL=
# Optional: write eval's governance audit rows into the hash-chained audit DB. Empty = eval logs events.
EVAL_AUDIT_DATABASE_URL=

# FR-MEMORY-122 — the company-brain capture master switch. DEFAULT OFF. When false (or unset), AUTH and
# CHAT emit NO interaction-events and behave exactly as before — safe to deploy at any time, including
# during a live team test. Set to true ONLY when you intend to start recording platform work-interactions;
# even then, a subject is captured only after they have acknowledged the monitoring notice (FR-EVAL-001).
# Turning capture on also requires CHAT_AUDIT_DATABASE_URL to be set (the brain link).
CAPTURE_ENABLED=false

# The chat LLM (ollama) behind translation/assistant sits behind the compose profile "llm" and is OFF on
# the 4 GB box - bge-m3 embeddings + a 3b chat model do not fit together. After resizing the VPS (8 GB
# recommended), uncomment the next line and redeploy; deploy.sh then also pulls the chat model
# (qwen2.5:3b-instruct by default - keep it in sync with deploy/vps/ai/tenants/org-cyberskill.yaml).
# Full steps: docs/deploy/ai-gateway-and-embeddings.md.
#COMPOSE_PROFILES=llm
