# CyberOS P0 deploy env - copy to .env.p0 on the host and replace every placeholder. .env.p0 is
# gitignored (it holds the DB password). The Google client id/secret are NOT here; they go into the IdP
# config row via the admin API (runbook Step 4).

# The single public origin the team uses. CYBEROS_APP_URL must be https://CYBEROS_APP_DOMAIN.
CYBEROS_APP_DOMAIN=os.cyberskill.world
CYBEROS_APP_URL=https://os.cyberskill.world

COMPOSE_PROJECT_NAME=cyberos-p0
CYBEROS_RUST_VERSION=1.88.0
CYBEROS_IMAGE_TAG=local

# Supabase database (managed Postgres). auth and chat share ONE Supabase project - their tables do not
# collide, and neither service auto-migrates, so a single database holds both. Use the SESSION POOLER
# connection string from the Supabase dashboard (Project Settings -> Database -> Connection string ->
# "Session pooler"): it is IPv4 and session-mode, so the per-request tenant scoping and role GUCs behave.
# Do NOT use the transaction pooler (port 6543) - it would drop the session-scoped app.roles setting.
# Format (replace PROJECT-REF, PASSWORD, and REGION with your project's values; keep sslmode=require):
#   postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Both URLs point at the same project/database for P0; split into two projects later if you want isolation.
AUTH_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
CHAT_DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Optional: write chat's hash-chained audit log into the memory DB. Leave empty for P0 (chat logs events).
CHAT_AUDIT_DATABASE_URL=
