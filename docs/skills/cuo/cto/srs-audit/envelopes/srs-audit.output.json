{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cto/srs-audit/envelopes/srs-audit.output.json",
  "title": "srs-audit output envelope",
  "type": "object",
  "required": ["skill_id", "skill_version", "rubric_version", "total_srss", "per_srs"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string", "const": "cuo/cto/srs-audit"},
    "skill_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "rubric_version": {"type": "string"},
    "total_srss": {"type": "integer", "minimum": 1},
    "exit_code": {"type": "integer", "enum": [0, 1, 2, 3]},
    "per_srs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["srs_path", "audit_path", "audited_srs_sha256", "overall_status"],
        "additionalProperties": false,
        "properties": {
          "srs_path": {"type": "string"},
          "audit_path": {"type": "string"},
          "audited_srs_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "overall_status": {"type": "string", "enum": ["pass", "needs_human", "fail", "stale"]},
          "iteration_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "hitl_pending": {"type": "boolean"},
    "next_skill_recommendation": {"oneOf": [{"type": "string"}, {"type": "null"}]},
    "trace_id": {"type": "string", "format": "uuid"},
    "audit_row_id": {"type": "string"}
  }
}
