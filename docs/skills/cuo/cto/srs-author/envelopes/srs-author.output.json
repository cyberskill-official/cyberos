{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cto/srs-author/envelopes/srs-author.output.json",
  "title": "srs-author output envelope",
  "type": "object",
  "required": ["skill_id", "skill_version", "outcome", "prd_path"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string", "const": "cuo/cto/srs-author"},
    "skill_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "trace_id": {"type": "string", "format": "uuid"},
    "outcome": {"type": "string", "enum": ["SRS_COMPLETE", "HALTED_HITL", "REFUSED_NON_PASS_PRD", "EXHAUSTED", "USER_ABORTED"]},
    "prd_path": {"type": "string"},
    "srs_path": {"type": "string"},
    "srs_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "srs_status": {"type": "string", "enum": ["draft", "in_review", "approved", "superseded"]},
    "srs_iteration": {"type": "integer", "minimum": 1},
    "security_review_required": {"type": "boolean"},
    "next_skill_recommendation": {"oneOf": [{"type": "string", "pattern": "^cuo/[a-z0-9-]+/[a-z0-9-]+$"}, {"type": "null"}]},
    "hitl_request_path": {"type": "string"},
    "refusal_reason": {"type": "string"},
    "audit_row_id": {"type": "string"}
  }
}
