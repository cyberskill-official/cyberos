{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cpo/prd-author/envelopes/prd-author.output.json",
  "title": "prd-author output envelope",
  "description": "Output contract for cuo/cpo/prd-author.",
  "type": "object",
  "required": ["skill_id", "skill_version", "outcome", "brief_path"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string", "const": "cuo/cpo/prd-author"},
    "skill_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "trace_id": {"type": "string", "format": "uuid"},
    "outcome": {
      "type": "string",
      "enum": [
        "PRD_COMPLETE",
        "HALTED_HITL",
        "REFUSED_REJECTED_BRIEF",
        "REFUSED_REVISE_NEEDS_OVERRIDE",
        "EXHAUSTED",
        "USER_ABORTED"
      ]
    },
    "brief_path": {"type": "string", "minLength": 1},
    "prd_path": {"type": "string", "minLength": 1, "description": "Required when outcome ∈ {PRD_COMPLETE, HALTED_HITL, EXHAUSTED, USER_ABORTED}."},
    "prd_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "prd_status": {"type": "string", "enum": ["draft", "in_review", "approved", "superseded"]},
    "prd_iteration": {"type": "integer", "minimum": 1},
    "authority_distribution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "human_edited": {"type": "integer", "minimum": 0},
        "human_confirmed": {"type": "integer", "minimum": 0},
        "llm_explicit": {"type": "integer", "minimum": 0},
        "llm_implicit": {"type": "integer", "const": 0, "description": "MUST be 0 per INV-002 — Goals cannot carry llm-implicit authority."}
      }
    },
    "open_questions_count": {"type": "integer", "minimum": 0},
    "eu_ai_act_risk_class": {"type": "string", "enum": ["not_ai", "minimal", "limited", "high"]},
    "confidentiality": {"type": "string", "enum": ["public", "internal", "client_confidential", "regulated"]},
    "next_skill_recommendation": {
      "oneOf": [
        {"type": "string", "pattern": "^cuo/[a-z0-9-]+/[a-z0-9-]+$"},
        {"type": "null"}
      ],
      "description": "Will default to 'cuo/cpo/prd-audit' once that skill ships at registry v0.2.5; null at v0.1.0."
    },
    "hitl_request_path": {"type": "string", "description": "Required when outcome == HALTED_HITL."},
    "hitl_category": {"type": "string", "enum": ["feature_flag_strategy_unspecified", "rollout_plan_undefined", "telemetry_gap", "approval_workflow_unclear", "rollback_trigger_missing", "ai_act_high_risk_classification", "security_review_required", "reservation_override_confirmation"]},
    "refusal_reason": {"type": "string", "description": "Required when outcome ∈ {REFUSED_REJECTED_BRIEF, REFUSED_REVISE_NEEDS_OVERRIDE}."},
    "audit_row_id": {"type": "string", "pattern": "^evt_[0-9a-f-]{36}$|^evt_[0-9A-HJKMNP-TV-Z]{26}$"}
  }
}
