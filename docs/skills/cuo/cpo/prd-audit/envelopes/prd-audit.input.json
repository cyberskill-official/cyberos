{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cpo/prd-audit/envelopes/prd-audit.input.json",
  "title": "prd-audit input envelope",
  "type": "object",
  "required": ["prd_paths"],
  "additionalProperties": false,
  "_note": "rubric_version, upstream_context, trace_id, caller_persona, max_iterations_per_prd are optional with documented defaults.",
  "properties": {
    "prd_paths": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "rubric_version": {
      "type": "string",
      "pattern": "^prd_rubric@\\d+\\.\\d+$",
      "default": "prd_rubric@1.0"
    },
    "upstream_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_skill": {"type": "string", "pattern": "^cuo/[a-z0-9-]+/[a-z0-9-]+$"},
        "manifest_path": {"type": "string", "minLength": 1}
      }
    },
    "trace_id": {"type": "string", "format": "uuid"},
    "caller_persona": {"type": "string", "pattern": "^cuo(-[a-z0-9-]+)?$"},
    "max_iterations_per_prd": {"type": "integer", "minimum": 1, "maximum": 20, "default": 5}
  }
}
