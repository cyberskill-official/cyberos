{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cpo/prd-audit/envelopes/prd-audit.output.json",
  "title": "prd-audit output envelope",
  "type": "object",
  "required": ["skill_id", "skill_version", "rubric_version", "total_prds", "overall_status_counts", "per_prd"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string", "const": "cuo/cpo/prd-audit"},
    "skill_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "rubric_version": {"type": "string", "pattern": "^prd_rubric@\\d+\\.\\d+$"},
    "total_prds": {"type": "integer", "minimum": 1},
    "overall_status_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pass": {"type": "integer", "minimum": 0},
        "needs_human": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0},
        "stale": {"type": "integer", "minimum": 0}
      }
    },
    "exit_code": {"type": "integer", "enum": [0, 1, 2, 3]},
    "per_prd": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prd_path", "audit_path", "audited_prd_sha256", "overall_status", "iteration_count"],
        "additionalProperties": false,
        "properties": {
          "prd_path": {"type": "string", "minLength": 1},
          "audit_path": {"type": "string", "minLength": 1},
          "audited_prd_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "overall_status": {"type": "string", "enum": ["pass", "needs_human", "fail", "stale"]},
          "iteration_count": {"type": "integer", "minimum": 1},
          "error_count": {"type": "integer", "minimum": 0},
          "warning_count": {"type": "integer", "minimum": 0},
          "needs_human_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "hitl_pending": {"type": "boolean"},
    "hitl_request_path": {"type": "string"},
    "next_skill_recommendation": {
      "oneOf": [
        {"type": "string", "pattern": "^cuo/[a-z0-9-]+/[a-z0-9-]+$"},
        {"type": "null"}
      ]
    },
    "trace_id": {"type": "string", "format": "uuid"},
    "audit_row_id": {"type": "string", "pattern": "^evt_[0-9a-f-]{36}$|^evt_[0-9A-HJKMNP-TV-Z]{26}$"}
  }
}
