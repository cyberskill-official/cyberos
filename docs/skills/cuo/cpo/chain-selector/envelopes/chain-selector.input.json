{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cpo/chain-selector/envelopes/chain-selector.input.json",
  "title": "chain-selector input envelope",
  "type": "object",
  "required": ["brief_path"],
  "additionalProperties": false,
  "properties": {
    "brief_path": {"type": "string", "minLength": 1},
    "user_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chain_profile", "reason"],
      "properties": {
        "chain_profile": {"type": "string", "enum": ["lean", "standard", "full"]},
        "reason": {"type": "string", "minLength": 10}
      }
    },
    "trace_id": {"type": "string", "format": "uuid"},
    "caller_persona": {"type": "string", "pattern": "^cuo(-[a-z0-9-]+)?$"}
  }
}
