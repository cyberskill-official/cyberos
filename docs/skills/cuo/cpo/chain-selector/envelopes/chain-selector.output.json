{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyberos.cyberskill.world/skills/cuo/cpo/chain-selector/envelopes/chain-selector.output.json",
  "title": "chain-selector output envelope",
  "type": "object",
  "required": ["skill_id", "skill_version", "brief_path", "chain_profile", "chain_plan"],
  "additionalProperties": false,
  "properties": {
    "skill_id": {"type": "string", "const": "cuo/cpo/chain-selector"},
    "skill_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "trace_id": {"type": "string", "format": "uuid"},
    "brief_path": {"type": "string"},
    "chain_profile": {"type": "string", "enum": ["lean", "standard", "full"]},
    "auto_profile": {"type": "string", "enum": ["lean", "standard", "full"], "description": "What the rules selected before user override; equal to chain_profile when no override."},
    "user_override_reason": {"type": "string"},
    "chain_plan": {
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": {"type": "string", "pattern": "^cuo/[a-z0-9-]+/[a-z0-9-]+$"}
    },
    "chain_plan_path": {"type": "string", "description": "Path to the <slug>.chain-plan.md artefact."},
    "chain_plan_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "audit_row_id": {"type": "string"}
  }
}
