# services/obs-collector/config/auth/tokens.example
#
# FR-OBS-001 §1 #2 + §3 — Per-service bearer-token file. The CyberOS
# ingress gate reads this on every request. Format: <service-name> <bearer-token>
#
# The real tokens.live (with actual secrets) MUST NOT be committed; provision it
# from your secret store and mount it read-only into /etc/cyberos-obs/tokens.live.

ai-gateway REPLACE-ME-AI-GATEWAY-TOKEN
auth-service REPLACE-ME-AUTH-SERVICE-TOKEN
chat-service REPLACE-ME-CHAT-SERVICE-TOKEN
memory-writer REPLACE-ME-MEMORY-WRITER-TOKEN
mcp-router REPLACE-ME-MCP-ROUTER-TOKEN
