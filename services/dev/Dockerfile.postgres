# CyberOS dev Postgres: pgvector (embeddings) on PG16.
#
# Stock Postgres 16 plus pgvector, via the official pgvector/pgvector image. Apache AGE was removed: the
# memory layer-2 graph is the relational l2_entity / l2_edge tables (traversed with recursive CTEs), so no
# graph extension is needed. pgcrypto and uuid-ossp ship in the base image's contrib and are enabled by
# services/dev/postgres-init.sql. This image now matches any managed Postgres (pgvector-only), so local
# and a managed cloud Postgres run the same schema.
FROM pgvector/pgvector:pg16
