{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cyberos-ai usage v1",
  "type": "object",
  "required": ["schema_version", "tenant", "month", "cap_usd", "spent_usd", "spent_pct", "calls", "top_models_by_spend"],
  "properties": {
    "schema_version": { "const": "v1" },
    "tenant": { "type": "string" },
    "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "cap_usd": { "type": "number" },
    "spent_usd": { "type": "number" },
    "spent_pct": { "type": "number" },
    "calls": { "type": "integer", "minimum": 0 },
    "top_models_by_spend": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "spend_usd", "calls"],
        "properties": {
          "model": { "type": "string" },
          "spend_usd": { "type": "number" },
          "calls": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
