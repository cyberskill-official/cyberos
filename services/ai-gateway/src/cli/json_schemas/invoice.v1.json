{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cyberos-ai invoice export v1",
  "type": "object",
  "required": ["schema_version", "tenant", "period", "total_usd", "rows"],
  "properties": {
    "schema_version": { "const": "v1" },
    "tenant": { "type": "string" },
    "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "total_usd": { "type": "number" },
    "format": { "type": "string" },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "model", "calls", "cost_usd"],
        "properties": {
          "date": { "type": "string" },
          "model": { "type": "string" },
          "calls": { "type": "integer", "minimum": 0 },
          "cost_usd": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
