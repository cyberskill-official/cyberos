{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cyberos-ai models list v1",
  "type": "object",
  "required": ["schema_version", "models"],
  "properties": {
    "schema_version": { "const": "v1" },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "model", "alias"],
        "properties": {
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "alias": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
