FROM python:3.11-slim

WORKDIR /app
COPY sidecar/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY sidecar /app/sidecar
COPY checksums /app/checksums

ENV BGE_M3_MODEL_PATH=/models/bge-m3
ENV BGE_M3_CHECKSUM_PATH=/app/checksums/bge-m3.sha256
EXPOSE 5060

CMD ["uvicorn", "sidecar.bge_m3_sidecar:app", "--host", "0.0.0.0", "--port", "5060"]
