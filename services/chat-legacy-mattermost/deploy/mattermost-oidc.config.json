{
  "GitLabSettings": {
    "Enable": true,
    "Id": "cyberos-chat",
    "Secret": "${CYBEROS_CHAT_OIDC_SECRET}",
    "Scope": "openid email profile",
    "AuthEndpoint": "https://auth.cyberos.world/v1/auth/op/authorize",
