{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/cyberskill-official/code-audit-framework/blob/main/schemas/feedback.v1.json",
  "title": "code-audit-framework per-run field-feedback record (feedback@1)",
  "description": "One record per external run: the machine half is generated by `code-audit-validate --run DIR --emit-feedback`; the human half is adjudicated afterwards. Records live in the private field-data repository (client-coded, sanitized, R8 applies). Field semantics and the calibration pipeline: evals/TESTING-PROTOCOL.md.",
  "type": "object",
  "required": ["run_id", "protocol_version", "validator_version", "report_ref", "retro_score"],
  "properties": {
    "run_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "protocol_version": { "type": ["string", "null"], "pattern": "^v\\d+\\.\\d+\\.\\d+$" },
    "validator_version": { "type": "string" },
    "agent": {
      "type": "object",
      "properties": { "cli": { "type": "string" }, "model": { "type": "string" } }
    },
    "config": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["gated", "autonomous"] },
        "depth": { "enum": ["quick", "standard", "deep"] },
        "loop_budget": { "type": "integer" },
        "stack": { "type": "array", "items": { "type": "string" } }
      }
    },
    "report_ref": { "type": "string" },
    "retro_score": { "type": "integer", "minimum": 0, "maximum": 20 },
    "retro_items": {
      "type": "object",
      "description": "Only rubric items scored < 2, keyed q1..q10, each with a one-line note.",
      "additionalProperties": { "type": ["integer", "string"] }
    },
    "validator_false_positives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "why_wrong"],
        "properties": {
          "code": { "type": "string" },
          "detail_excerpt": { "type": "string" },
          "why_wrong": { "type": "string" }
        }
      }
    },
    "validator_misses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "candidate_code": { "type": "string" }
        }
      }
    },
    "denylist_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["list", "value"],
        "properties": {
          "list": { "enum": ["GUI_TOOLS", "SECRET_PATTERNS"] },
          "value": { "type": "string" }
        }
      }
    },
    "fabrication_check": {
      "type": "object",
      "properties": {
        "sampled": { "type": "integer", "minimum": 0 },
        "mismatched": { "type": "integer", "minimum": 0 }
      }
    },
    "cross_model": { "type": ["object", "null"] },
    "waivers": {
      "type": "object",
      "properties": {
        "active": { "type": "integer" },
        "expired_flagged": { "type": "integer" }
      }
    },
    "violations_total": { "type": "integer" },
    "narrative": { "type": "string" }
  }
}
