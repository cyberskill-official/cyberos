  "source_tiers": [
    {
      "pattern": "company/locked-decisions.md",
      "rationale": "Founder-level locked decisions are append-only and immutable per \u00a79.6; never auto-overridden by anything else.",
      "tier": 1
    },
    {
      "pattern": "company/**",
      "rationale": "Company-level scope (values, glossary, compliance, history) carries org-wide authority; outranks any per-module or per-project memory.",
      "tier": 3
    },
    {
      "pattern": "memories/decisions/**",
      "rationale": "Founder/CEO decisions recorded as DEC-NNN are second-most-authoritative; outrank facts/projects/preferences but can be superseded by company/locked-decisions on conflict.",
      "tier": 5
    },
    {
      "pattern": "memories/refinements/**",
      "rationale": "Protocol refinements (REF-NNN) carry the same authority as the decisions they implement; tied with memories/decisions/.",
      "tier": 5
    },
    {
      "pattern": "module/**",
      "rationale": "Module-level memories (per-capability) are authoritative within their module's domain; outrank facts/projects/preferences.",
      "tier": 8
    },
    {
      "pattern": "memories/facts/**",
      "rationale": "Facts derived from authoritative sources (PRD/SRS/architecture) are authoritative for descriptive content but yield to decisions on policy questions.",
      "tier": 10
    },
    {
      "pattern": "client/**",
      "rationale": "Per-client memories carry client-engagement authority but yield to company-level policy on cross-client questions.",
      "tier": 12
    },
    {
      "pattern": "memories/projects/**",
      "rationale": "Per-project working memory; authoritative within its project but yields to company/module on cross-cutting questions.",
      "tier": 15
    },
    {
      "pattern": "project/**",
      "rationale": "This-project working memory (the cyberos repo's own project/ scope); same tier as memories/projects/.",
      "tier": 15
    },
    {
      "pattern": "persona/**",
      "rationale": "Agent persona/role-card memories; yield to company/module/decisions on factual questions.",
      "tier": 18
    },
    {
      "pattern": "memories/people/**",
      "rationale": "Person-graph memories; descriptive.",
      "tier": 20
    },
    {
      "pattern": "memories/preferences/**",
      "rationale": "Personal preferences and feedback memories; subject-specific; yield to org-level decisions.",
      "tier": 25
    },
    {
      "pattern": "member/**",
      "rationale": "Per-subject personal memories; authoritative for that subject only; yield to company/module on org-level questions.",
      "tier": 30
    },
    {
      "pattern": "memories/drift/**",
      "rationale": "Drift candidates flagged by \u00a78.6 \u2014 informational; never authoritative.",
      "tier": 80
    },
    {
      "pattern": "*",
      "rationale": "Default \u2014 lowest priority unless overridden by a more-specific pattern above.",
      "tier": 99
    }
  ],
